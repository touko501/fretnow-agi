# ═══════════════════════════════════════════════════════════════════════════
# FRETNOW AGI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════════════════

# ──── SERVER ────
NODE_ENV=development
PORT=3000

# ──── DATABASE (PostgreSQL) ────
DATABASE_URL=postgresql://user:password@localhost:5432/fretnow?schema=public

# ──── JWT AUTH ────
JWT_SECRET=your-jwt-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ──── STRIPE CONNECT (paiements marketplace) ────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──── MOBILIC (conformité temps de travail) ────
MOBILIC_CLIENT_ID=
MOBILIC_CLIENT_SECRET=
MOBILIC_REDIRECT_URI=https://your-domain.com/api/mobilic/callback

# ──── EMAIL (SMTP) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@fretnow.fr

# ──── GRAPHHOPPER (routing optionnel, 50 req/jour gratuit) ────
GRAPHHOPPER_API_KEY=

# ──── TELEGRAM BOT (notifications optionnel) ────
TELEGRAM_BOT_TOKEN=

# ──── FRONTEND ────
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ──── UPLOAD ────
MAX_FILE_SIZE=10mb
UPLOAD_DIR=./uploads
